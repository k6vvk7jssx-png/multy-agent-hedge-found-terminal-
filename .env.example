# ============================================================
# Automated Due Diligence Terminal - Environment Variables
# ============================================================
# ISTRUZIONI: Copia questo file in ".env" e sostituisci
# i placeholder con le tue chiavi reali.
# MAI committare il file ".env" su Git.
# ============================================================

# --- FASE 1: CORE (Obbligatorio per il funzionamento) ---
# Genera la chiave su: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- FASE 2: UPGRADE ISTITUZIONALE (Opzionale) ---
# Financial Modeling Prep - dati storici 30 anni
# Genera la chiave su: https://financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# Tavily - radar macro-economico e news sentiment
# Genera la chiave su: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# --- FASE 3: MCP & ALTERNATIVE DATA ---
# Brave Search - per l'Alternative Data Analyst (Twitter/Reddit sentiment)
# Genera la chiave gratuita su: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here
